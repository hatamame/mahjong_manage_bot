{
  "name": "discord-mahjong",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "register": "node scripts/register-commands.mjs",
    "db:init": "wrangler d1 execute mahjong --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute mahjong --local --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
